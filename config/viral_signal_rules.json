                              }
                          ],
    "source_acquisition":  {
                               "startup_safe_route":  "manual_public_search",
                               "allowed_without_extra_approval":  [
                                                                      "manual_public_search",
                                                                      "viewstats_manual_export",
                                                                      "apify_csv_already_exported_by_user"
                                                                  ],
                               "requires_explicit_approval":  [
                                                                  "youtube_data_api",
