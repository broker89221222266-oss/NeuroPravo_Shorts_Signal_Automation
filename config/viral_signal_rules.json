                 },
    "minimum_review_fields":  [
                                  "source_url",
                                  "platform",
                                  "published_at",
                                  "views",
                                  "likes",
                                  "comments",
                                  "shares",
                                  "saves",
                                  "topic_hint",
                                  "selection_reason",
                                  "metrics_completeness",
                                  "recency_quality",
                                  "adaptation_distance"
                              ],
    "controller_rules":  [
                             "Do not assign script writing before source_candidates_review.md exists.",
