                                                                                 "source_candidates_review.md",
                                                                                 "batch_summary.md"
                                                                             ]
                                                    }
                           },
    "statuses":  {
                     "viral_candidate":  "Fresh, scored, relevant, with visible public signal and transferable mechanic.",
