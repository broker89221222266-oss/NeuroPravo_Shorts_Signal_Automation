{
  "project": "NeuroPravo short video signal automation",
  "window_days": 30,
  "default_min_score": 70,
  "manual_review_required": true,
  "publishing_allowed": false,
  "rendering_allowed": false,
  "external_upload_allowed": false,
  "allowed_platforms": [
    "YouTube Shorts",
    "TikTok",
    "Instagram Reels",
    "VK Clips",
    "Dzen",
    "ViewStats",
    "Apify",
    "Manual"
  ],
  "required_fields": [
    "source_url",
    "platform",
    "published_at",
    "author",
    "title_or_caption",
    "views",
    "likes",
    "comments",
    "shares",
    "saves",
    "duration_sec",
    "topic_hint",
    "notes"
  ],
  "topics": [
    "долги",
    "долг",
    "договор",
    "застройщик",
    "ремонт",
    "наследство",
    "алименты",
    "маркетплейс",
    "возврат товара",
    "предпринимательские долги",
    "кассовый разрыв",
    "клиент не платит",
    "ошибка в переписке",
    "ошибка в документах",
    "поверил на слово",
    "подписал не глядя",
    "думал что прав но проиграл"
  ],
  "fit_signals": [
    "деньги",
    "долг",
    "договор",
    "аванс",
    "клиент",
    "оплата",
    "срок",
    "переписка",
    "документы",
    "чек",
    "возврат",
    "спор",
    "наследство",
    "алименты",
    "ремонт",
    "маркетплейс",
    "застройщик",
    "подписал",
    "обещал",
    "устно"
  ],
  "selection_rules": {
    "min_final_score": 70,
    "min_neuropravo_fit_score": 40,
    "max_duration_sec": 180
  },
  "scoring": {
    "raw_score": "views + comments * 30 + likes * 3 + shares * 30 + saves * 40",
    "engagement_score": "normalized engagement per view, capped at 100",
    "recency_score": "100 for today, linearly down to 0 after window_days",
    "neuropravo_fit_score": "topic and conflict signal match, capped at 100",
    "final_score": "raw_score 35% + engagement_score 20% + recency_score 20% + neuropravo_fit_score 25%"
  }
}
